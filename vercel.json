{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "installCommand": "npm install",
  "builds": [
    {
      "src": "dist/server.cjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/dist/server.cjs"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/server.cjs"
    }
  ]
}